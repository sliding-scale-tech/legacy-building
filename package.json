{
	"name": "mobile-starter",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:native": "turbo -F native dev",
		"dev:web": "turbo -F web dev",
		"dev:admin": "turbo -F admin dev",
		"dev:server": "turbo -F @mobile-starter/backend dev",
		"dev:setup": "turbo -F @mobile-starter/backend dev:setup",
		"check": "biome check --write .",
		"precommit": "lint-staged",
		"prepare": "husky"
	},
	"dependencies": {
		"@mobile-starter/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@mobile-starter/config": "workspace:*",
		"husky": "^9.1.7",
		"lint-staged": "^16.1.2",
		"turbo": "^2.8.12",
		"typescript": "catalog:"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write ."
		]
	},
	"packageManager": "pnpm@10.28.0"
}
