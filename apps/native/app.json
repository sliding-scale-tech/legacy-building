{
	"expo": {
		"scheme": "legacy-building",
		"userInterfaceStyle": "automatic",
		"orientation": "default",
		"web": {
			"bundler": "metro"
		},
		"name": "legacy-building",
		"slug": "legacy-building",
		"plugins": [
			"expo-font",
			[
				"expo-image-picker",
				{
					"photosPermission": "Legacy Building uses your photos so you can choose a profile picture.",
					"cameraPermission": "Legacy Building uses your camera so you can take a profile picture."
				}
			],
			"@react-native-community/datetimepicker",
			[
				"expo-audio",
				{
					"microphonePermission": "Legacy Building uses your microphone to record journal entries."
				}
			]
		],
		"experiments": {
			"typedRoutes": true,
			"reactCompiler": true
		},
		"android": {
			"package": "com.legacybuilding.app"
		},
		"ios": {
			"bundleIdentifier": "com.legacybuilding.app"
		},
		"extra": {
			"eas": {
				"projectId": "beb8a12c-54c4-448e-a60f-411bafbeacef"
			}
		},
		"owner": "sliding-scale"
	}
}
